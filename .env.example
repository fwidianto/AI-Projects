# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
# PostgreSQL connection string
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://postgres:password@localhost:5432/job_intelligence

# Or use SQLite for development (comment out DATABASE_URL above)
# DATABASE_URL=sqlite:///./data/job_intelligence.db

# =============================================================================
# API KEYS
# =============================================================================
# OpenAI API key for LLM features
OPENAI_API_KEY=sk-your-api-key-here

# Optional: LinkedIn API credentials (if using official API)
LINKEDIN_CLIENT_ID=your-linkedin-client-id
LINKEDIN_CLIENT_SECRET=your-linkedin-client-secret

# =============================================================================
# APPLICATION SETTINGS
# =============================================================================
# Application environment (development, staging, production)
APP_ENV=development

# Secret key for session management
SECRET_KEY=your-super-secret-key-change-in-production

# Debug mode
DEBUG=true

# =============================================================================
# SCRAPING CONFIGURATION
# =============================================================================
# Rate limiting (requests per second)
SCRAPE_RATE_LIMIT=1

# Maximum retries per request
SCRAPE_MAX_RETRIES=3

# Request timeout (seconds)
SCRAPE_TIMEOUT=30

# Enable/disable specific scrapers
ENABLE_INDEED_SCRAPER=true
ENABLE_GLINTS_SCRAPER=true
ENABLE_JOBSTREET_SCRAPER=true
ENABLE_LINKEDIN_SCRAPER=false

# =============================================================================
# ML MODEL CONFIGURATION
# =============================================================================
# HuggingFace token (optional, for private models)
HF_TOKEN=

# Model names
SKILL_MATCHING_MODEL=all-MiniLM-L6-v2
JOB_CLASSIFIER_MODEL=facebook/bart-large-mnli

# =============================================================================
# REPORTING CONFIGURATION
# =============================================================================
# Email settings (for report delivery)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# Report recipient
REPORT_RECIPIENT=recipient@example.com

# =============================================================================
# LOGGING
# =============================================================================
LOG_LEVEL=INFO
LOG_FILE=logs/app.log